# ClaimIQ — Environment Variables
# Copy this file to .env and fill in your values

# ── App ───────────────────────────────────────────
APP_NAME=ClaimIQ
DEBUG=True

# ── Database ──────────────────────────────────────
# SQLite (default, works out of the box):
DATABASE_URL=sqlite:///./claimiq.db

# PostgreSQL (production-ready, uncomment & fill):
# DATABASE_URL=postgresql://claimiq_user:your_password@localhost:5432/claimiq_db

# ── Security ──────────────────────────────────────
SECRET_KEY=claimiq-super-secret-key-change-this-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── STP Thresholds ────────────────────────────────
STP_AMOUNT_LIMIT=5000.0
FRAUD_SCORE_THRESHOLD=70.0
AUTO_APPROVE_SCORE=30.0

# ── File Upload ───────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
